# ─── Discord ──────────────────────────────────────────────────────────────────
# توكن البوت من Discord Developer Portal
DISCORD_TOKEN=

# معرّف التطبيق (Application ID) من Developer Portal
CLIENT_ID=

# معرّف السيرفر الذي سيتم تسجيل الأوامر فيه
GUILD_ID=

# بادئة الأوامر النصية (الافتراضي: -)
PREFIX=-

# ─── قاعدة البيانات (PostgreSQL) ─────────────────────────────────────────────
# رابط الاتصال بقاعدة البيانات
# مثال محلي:    postgresql://postgres:password@localhost:5432/fantasybot
# مثال Railway: يُملأ تلقائياً من متغيرات Railway
DATABASE_URL=

# ─── خادم Health Check ────────────────────────────────────────────────────────
# المنفذ الذي يستمع عليه خادم HTTP (يُملأ تلقائياً من Railway/Render)
PORT=3000
